<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.guiapplication.NumberCounterController">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label fx:id="countLabel" text="0" style="-fx-font-size: 40px; -fx-font-weight: bold;"/>

    <HBox alignment="CENTER" spacing="15.0">
        <Button fx:id="decreaseButton" text="Decrease" onAction="#onDecrease" prefWidth="100"/>
        <Button fx:id="increaseButton" text="Increase" onAction="#onIncrease" prefWidth="100"/>
    </HBox>

</VBox>